<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.AddsPlayer" parent="Theme.MaterialComponents.DayNight">
        <!-- Основні кольори -->
        <item name="colorPrimary">@color/kopiyka_blue</item>
        <item name="colorOnPrimary">@color/kopiyka_white</item>
        <item name="colorAccent">@color/kopiyka_yellow</item>

        <!-- Кольори тексту в полях введення -->
        <item name="android:textColorPrimary">@color/black</item>
        <item name="android:textColor">@color/black</item>
        <item name="android:textColorHint">@color/grey</item>   <!-- або темно-сірий -->

        <!-- Для TextInputLayout -->
        <item name="textInputStyle">@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox</item>
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>

    <style name="Theme.AddsPlayer.Settings" parent="Theme.AddsPlayer">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>

</resources>